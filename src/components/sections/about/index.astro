---
import { Image } from "astro:assets";
import Anchor from "../../ui/Anchor.astro";
import Container from "../../ui/Container.astro";
---

<Container id="about" title="About me">
  <div class="flex flex-col lg:flex-row gap-4 items-center">
    <div class="w-full flex justify-center lg:w-1/2 2xl:w-1/3">
      <Image
        src={"/my-picture.jpg"}
        alt="Diego Rezende"
        width={400}
        height={400}
        class="rounded-md"
      />
    </div>
    <div class="w-full lg:w-1/2 space-y-6">
      <p class="text-2xl text-justify font-semibold">
        Hello! I'm Diego Rezende, a software developer from Brazil with a
        passion for coding and learning new things. I'm currently in college,
        but I'm always on the lookout for challenges and opportunities. I’m a
        big fan of open-source and have created a few projects myself—feel free
        to check them out on my GitHub! I’ve been using Linux since high school
        (Arch btw)
      </p>
      <div class="hidden md:flex flex-row gap-4">
        <Anchor
          href="https://github.com/diegorezm"
          label="Github"
          icon="lucide:github"
          size="sm"
          variant="primary"
          target="_blank"
        />
        <Anchor
          href="https://linkedin.com/in/diegorezm"
          label="Linkedin"
          icon="lucide:linkedin"
          size="sm"
          variant="secondary"
          target="_blank"
        />
      </div>
      <div class="flex flex-row md:hidden gap-4 mt-4">
        <Anchor
          href="https://github.com/diegorezm"
          icon="lucide:github"
          size="md"
          variant="primary"
          target="_blank"
        />
        <Anchor
          href="https://linkedin.com/in/diegorezm"
          icon="lucide:linkedin"
          size="md"
          variant="secondary"
          target="_blank"
        />
      </div>
    </div>
  </div>
</Container>
