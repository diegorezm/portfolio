---
import type { Project } from "../../../types/project";

import { Image } from "astro:assets";
import Anchor from "../../ui/Anchor.astro";

type Props = {
  project: Project;
};

const { project } = Astro.props;
---

<div class="bg-background-alt rounded-default shadow-md h-fit flex flex-col">
  <Image
    src={project.image}
    alt={project.name}
    width={400}
    height={400}
    class="w-full h-1/2 object-cover rounded-t-default"
  />

  <div class="flex flex-col justify-between p-4 h-full">
    <div>
      <h2 class="text-lg font-bold text-foreground">{project.name}</h2>
      <p class="mt-2 text-md text-left">
        {project.description}
      </p>
    </div>

    <div
      class="flex flex-row justify-start gap-4 md:gap-0 md:justify-between mt-4"
    >
      <Anchor
        href={project.sourceCode}
        label="Source Code"
        icon="lucide:github"
        target="_blank"
        size="sm"
      />
      <Anchor
        href={project.details}
        label="Details"
        icon="lucide:info"
        target="_blank"
        size="sm"
        variant="outline"
      />
    </div>
  </div>
</div>
