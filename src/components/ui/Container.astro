---
import ColourfulSpan from "./ColourfulSpan.astro";

type Props = {
  id: string;
  title?: string;
  description?: string;
  className?: string;
};

const { title, id, description, className } = Astro.props as Props;
---

<div class={"container w-full h-full mx-auto" + " " + className} id={id}>
  {
    title && (
      <h1 class="mb-4">
        <ColourfulSpan
          label={title}
          color="accent"
          className="text-3xl font-bold"
        />
      </h1>
    )
  }
  {description && <p class="text-lg text-foreground-alt">{description}</p>}
  <slot />
</div>
