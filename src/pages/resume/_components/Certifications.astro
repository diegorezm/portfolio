---
type Certification = {
  label: string;
  href: string;
};

type Props = {
  certifications: Certification[];
  selectedLang: "en" | "pt-br";
};

import Anchor from "../../../components/ui/Anchor.astro";

const { certifications }: { certifications: Certification[] } = Astro.props;
const { selectedLang }: { selectedLang: "en" | "pt-br" } = Astro.props;
---

<section>
  <h2 class="resume-section-header">
    {selectedLang === "en" ? "Certifications" : "Certificações"}
  </h2>
  <ul class="flex flex-col gap-2 mb-2 md:list-disc list-inside">
    {
      certifications.map((cert) => (
        <li>
          <Anchor
            href={cert.href}
            icon="lucide:shield-check"
            size="sm"
            variant="ghost"
            label={cert.label}
            target="_blank"
          />
        </li>
      ))
    }
  </ul>
</section>
